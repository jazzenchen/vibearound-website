{
  "name": "vibearound-website",
  "private": true,
  "version": "0.1.0",
  "description": "Static marketing site and release hosting automation for VibeAround.",
  "scripts": {
    "dev": "npx wrangler@latest pages dev public --compatibility-date=2026-05-08",
    "deploy": "npx wrangler@latest pages deploy public --project-name=vibearound-ai --branch=main",
    "sync:releases": "node scripts/sync-release-assets.mjs",
    "setup:cloudflare": "node scripts/configure-cloudflare.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
