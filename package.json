{
  "name": "vibearound-website",
  "private": true,
  "version": "0.1.0",
  "description": "VibeAround marketing site, documentation, and release hosting automation.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "preview": "npm run build && npx wrangler@latest pages dev out --compatibility-date=2026-05-08",
    "deploy": "npm run build && npx wrangler@latest pages deploy out --project-name=vibearound-ai --branch=main",
    "sync:releases": "node scripts/sync-release-assets.mjs",
    "setup:cloudflare": "node scripts/configure-cloudflare.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fumadocs-core": "^16.10.2",
    "fumadocs-mdx": "^15.0.12",
    "fumadocs-ui": "^16.10.2",
    "lucide-react": "^1.18.0",
    "mermaid": "^11.15.0",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/mdx": "^2.0.13",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.55.0"
  }
}
